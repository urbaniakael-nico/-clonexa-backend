:root{
  --bg:#050505;--panel:#09090b;--card:#18181b;--line:#3f3f46;--text:#f8fafc;
  --muted:#a1a1aa;--red:#ef233c;--pink:#ff2bd6;--green:#00ff88;
}
*{box-sizing:border-box}
body{margin:0;min-height:100vh;background:radial-gradient(circle at 20% 10%,rgba(239,35,60,.22),transparent 28%),radial-gradient(circle at 80% 0,rgba(255,43,214,.16),transparent 28%),var(--bg);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,sans-serif;overflow-x:hidden}
.grid{position:fixed;inset:0;background-image:linear-gradient(rgba(255,255,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.035) 1px,transparent 1px);background-size:42px 42px;mask-image:linear-gradient(to bottom,rgba(0,0,0,.9),rgba(0,0,0,.18));pointer-events:none}
.login-shell{min-height:100vh;display:grid;place-items:center;padding:24px}
.login-card{width:min(460px,100%);background:linear-gradient(145deg,rgba(24,24,27,.94),rgba(9,9,11,.96));border:1px solid var(--line);border-radius:28px;padding:30px;box-shadow:0 0 70px rgba(239,35,60,.16),0 24px 80px rgba(0,0,0,.65);position:relative;overflow:hidden}
.login-card:before{content:"";position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,43,214,.08),transparent);transform:translateX(-100%);animation:sweep 5s infinite}
@keyframes sweep{50%,100%{transform:translateX(100%)}}
.brand{display:flex;align-items:center;justify-content:space-between;gap:12px;position:relative}
.wordmark{letter-spacing:.22em;font-weight:900;font-size:20px;color:#fff;text-shadow:0 0 22px rgba(239,35,60,.55)}
.status{font-size:11px;letter-spacing:.12em;color:var(--green);border:1px solid rgba(0,255,136,.34);border-radius:999px;padding:8px 10px;background:rgba(0,255,136,.05)}
.status i{display:inline-block;width:7px;height:7px;border-radius:99px;background:var(--green);box-shadow:0 0 16px var(--green);margin-right:6px}
h1{font-size:44px;line-height:1;margin:38px 0 10px}
p{color:var(--muted);margin:0 0 24px;line-height:1.5}
form{display:grid;gap:12px;position:relative}
label{font-size:12px;text-transform:uppercase;letter-spacing:.12em;color:#d4d4d8}
input{width:100%;background:#050505;border:1px solid #3f3f46;border-radius:16px;color:#fff;padding:15px 14px;font-size:15px;outline:none}
input:focus{border-color:var(--red);box-shadow:0 0 0 4px rgba(239,35,60,.13)}
button{margin-top:8px;border:0;border-radius:16px;padding:15px 16px;background:linear-gradient(135deg,var(--red),#ff1744);color:#fff;font-weight:900;font-size:15px;cursor:pointer;box-shadow:0 0 34px rgba(239,35,60,.3)}
.message{min-height:22px;color:#fca5a5;font-weight:700;font-size:13px}
footer{margin-top:22px;color:#71717a;font-size:12px;text-align:center;letter-spacing:.14em;text-transform:uppercase}
