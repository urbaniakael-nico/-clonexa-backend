APP_NAME=Clonexa Backend
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=clonexa
POSTGRES_PASSWORD=clonexa
POSTGRES_DB=clonexa
DATABASE_URL=postgresql+asyncpg://clonexa:clonexa@db:5432/clonexa

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DEFAULT_TIMEZONE=America/Bogota
CORS_ORIGINS=*
LOG_LEVEL=INFO

