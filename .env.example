# CLONEXA — Environment Example

# local | staging | production
ENVIRONMENT=production

# Railway PostgreSQL
# In Railway use:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

# Redis optional/future
# REDIS_URL=${{Redis.REDIS_URL}}
REDIS_URL=

# Security
# Use the same strong value for compatibility with current auth modules.
SECRET_KEY=change-this-in-production
JWT_SECRET_KEY=change-this-in-production
CLONEXA_JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Public URL
# Local tunnel only for development.
# Production must be Railway/domain:
# PUBLIC_BASE_URL=https://clonexa-production.up.railway.app
# PUBLIC_BASE_URL=https://app.clonexa.com
PUBLIC_BASE_URL=https://your-railway-or-domain-url
CLONEXA_PUBLIC_BASE_URL=https://your-railway-or-domain-url

# CORS
# For production set your domains separated by commas.
# Example:
# CORS_ORIGINS=https://clonexa-production.up.railway.app,https://app.clonexa.com
CORS_ORIGINS=*

# Railway runtime
PORT=8000
HOST=0.0.0.0

# Twilio Voice SDK / softphone web
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
# Up to 10 Twilio-owned E.164 numbers, comma separated.
TWILIO_OUTGOING_NUMBERS=
TWILIO_VALIDATE_SIGNATURES=true
